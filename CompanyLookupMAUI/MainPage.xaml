<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CompanyLookupMAUI.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Companies House Lookup">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <Label
                Text="Companies House Lookup"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label
                Text="Search by company number or company name."
                FontSize="16"
                HorizontalOptions="Center"
                TextColor="Gray" />

            <Frame Padding="16" CornerRadius="12">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Search Type" FontAttributes="Bold" />

                    <Picker
                        x:Name="SearchTypePicker"
                        SelectedIndexChanged="SearchTypePicker_OnSelectedIndexChanged">
                        <Picker.Items>
                            <x:String>Company Number</x:String>
                            <x:String>Company Name</x:String>
                        </Picker.Items>
                    </Picker>

                    <Entry
                        x:Name="SearchEntry"
                        Placeholder="Enter company number"
                        ClearButtonVisibility="WhileEditing" />

                    <Button
                        Text="Search"
                        Clicked="SearchButton_OnClicked" />

                </VerticalStackLayout>
            </Frame>

            <ActivityIndicator
                x:Name="LoadingIndicator"
                IsVisible="False"
                IsRunning="False" />

            <Label
                x:Name="StatusLabel"
                Text=""
                TextColor="Gray" />

            <Frame
                x:Name="CompanyProfileFrame"
                Padding="16"
                CornerRadius="12"
                IsVisible="False">

                <VerticalStackLayout Spacing="8">

                    <Label
                        Text="Company Details"
                        FontSize="20"
                        FontAttributes="Bold" />

                    <Label x:Name="CompanyNameLabel" />
                    <Label x:Name="CompanyNumberLabel" />
                    <Label x:Name="CompanyStatusLabel" />
                    <Label x:Name="CompanyTypeLabel" />
                    <Label x:Name="DateCreatedLabel" />
                    <Label x:Name="AddressLabel" />

                </VerticalStackLayout>
            </Frame>

            <Frame
                x:Name="SearchResultsFrame"
                Padding="16"
                CornerRadius="12"
                IsVisible="False">

                <VerticalStackLayout Spacing="8">

                    <Label
                        Text="Search Results"
                        FontSize="20"
                        FontAttributes="Bold" />

                    <CollectionView
                        x:Name="SearchResultsCollectionView"
                        SelectionMode="Single"
                        SelectionChanged="SearchResultsCollectionView_OnSelectionChanged">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame
                                    Margin="0,6"
                                    Padding="12"
                                    CornerRadius="10">
                                    <VerticalStackLayout>
                                        <Label
                                            Text="{Binding CompanyName}"
                                            FontAttributes="Bold" />
                                        <Label Text="{Binding CompanyNumber}" />
                                        <Label Text="{Binding CompanyStatus}" />
                                        <Label Text="{Binding AddressSnippet}" FontSize="12" TextColor="Gray" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>